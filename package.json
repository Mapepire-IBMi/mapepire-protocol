{
  "name": "@ibm/mapepire-protocol",
  "version": "0.1.0",
  "description": "Canonical protocol definitions for the Mapepire WebSocket protocol",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schemas": {
      "import": "./schemas/index.json",
      "require": "./schemas/index.json"
    },
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas",
    "PROTOCOL.md"
  ],
  "scripts": {
    "build": "tsup",
    "generate:schemas": "tsx scripts/generate-schemas.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run generate:schemas"
  },
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "keywords": [
    "mapepire",
    "ibm-i",
    "db2",
    "websocket",
    "protocol",
    "zod",
    "schema"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mapepire-IBMi/mapepire-protocol"
  }
}
